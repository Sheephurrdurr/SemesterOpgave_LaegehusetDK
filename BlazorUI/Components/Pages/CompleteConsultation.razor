@page "/complete-consultation"
@rendermode InteractiveServer
@using Facade.Interfaces
@using Facade.DTOs
@using UseCases.CompleteConsultation
@inject IConsultationQueries ConsultationQueries
@inject ICompleteConsultationUseCase CompleteUseCase

<div class="container mt-4">
    <h1 class="mb-4">Afslut Konsultation</h1>

    <div class="row d-flex">
        <div class="col-md-8 ">
            <div class="mb-3">
                <label class="form-label">Vælg konsultation</label>
                <select class="form-select" @bind="selectedConsultationId">
                    <option value="">Vælg konsultation...</option>
                    @foreach (var consultation in todaysConsultations)
                    {
                        <option value="@consultation.Id">@consultation.StartTime.ToString("HH:mm") - @consultation.PatientName (@consultation.DoctorName)</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Kommentar</label>
				<textarea class="form-control" @bind="note" rows="4" placeholder="Skriv notat om konsultationen..."></textarea>
            </div>

            <button type="button" class="btn btn-primary" @onclick="() => Complete(message)">Afslut Konsultation</button>

            @if (!string.IsNullOrEmpty(message))
            {
                <div class="alert @(message.StartsWith("Fejl") ? "alert-danger" : "alert-success") mt-3">
                    @message
                </div>
            }
        </div>
    </div>
</div>

@code {
    private IReadOnlyList<ConsultationDto> todaysConsultations = new List<ConsultationDto>();
    private Guid selectedConsultationId;
    private string note = "";
    private string message = "";

    protected override async Task OnInitializedAsync()
    {
        todaysConsultations = await ConsultationQueries.GetTodaysConsultationsAsync();
    }

    private async Task Complete(string note)
    {
        try
        {
            var request = new CompleteConsultationRequest
            {
                Id = selectedConsultationId,
                Note = note
            };

            await CompleteUseCase.ExecuteAsync(request);
            message = "Konsultation afsluttet!";
            note = "";
        }
        catch (Exception ex)
        {
            message = $"Fejl: {ex.Message}";
        }
    }
}
